<section id="Hero-{{ section.id }}" class="hero-nexora">
  {% if section.settings.video_url != blank %}
    <video class="hero-video" autoplay loop muted playsinline aria-hidden="true">
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {% endif %}
  
  <div class="hero-overlay"></div>
  
  <div class="container hero-content-wrapper">
    <div class="hero-text-align-{{ section.settings.alignment }}">
      {% if section.settings.subheading != blank %}
        <span class="hero-subheading">{{ section.settings.subheading | escape }}</span>
      {% endif %}
      
      <h1 class="hero-title">
        {{ section.settings.heading | escape }}
      </h1>
      
      {% if section.settings.text != blank %}
        <p class="hero-description">{{ section.settings.text | escape }}</p>
      {% endif %}
      
      <div class="hero-cta-group">
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link | default: '#' }}" class="btn-nexora">
            {{ section.settings.button_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-nexora {
    position: relative;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: #030303;
  }
  .hero-video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: 1;
    opacity: 0.4;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(3,3,3,0.2) 0%, rgba(3,3,3,0.9) 100%);
    z-index: 2;
  }
  .hero-content-wrapper {
    position: relative;
    z-index: 3;
  }
  .hero-text-align-center { text-align: center; max-width: 800px; margin: 0 auto; }
  .hero-text-align-left { text-align: left; max-width: 750px; }
  
  .hero-subheading {
    display: block;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-accent-blue);
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 2rem;
    background: linear-gradient(180deg, #FFFFFF 0%, #A2A2A2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-description {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }
</style>

{% schema %}
{
  "name": "Nexora Animated Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Architecture of Intelligence"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "NEXORA ECOSYSTEM v2.0"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Immersive computing nodes, continuous-wear biometrics, and autonomous assistant lattices built to align with human workflows."
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "MP4 Video URL",
      "info": "Provide an absolute URL to an MP4 asset hosted in your Shopify files."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Deploy Core Hardware"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Nexora Animated Hero"
    }
  ]
}
{% endschema %}
