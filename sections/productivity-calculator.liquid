<section class="calculator-section container" id="Calc-{{ section.id }}">
  <div class="calc-grid glass-panel">
    <div class="calc-inputs">
      <h2>{{ section.settings.heading | escape }}</h2>
      <p class="calc-desc">{{ section.settings.subtext | escape }}</p>
      
      <div class="input-group">
        <label for="hours-spent-{{ section.id }}">Manual Overhead Tasks (Hours / Week)</label>
        <input type="range" id="hours-spent-{{ section.id }}" min="5" max="60" value="35" class="slider">
        <span class="value-display" id="hours-value-{{ section.id }}">35 Hours</span>
      </div>

      <div class="input-group">
        <label for="device-efficiency-{{ section.id }}">Assigned Compute Engine Node</label>
        <select id="device-efficiency-{{ section.id }}" class="calc-select">
          <option value="0.40">Nexora Wearable Ring S4 (40% Overhead Mitigation)</option>
          <option value="0.65" selected>Nexora Node X Matrix (65% Overhead Mitigation)</option>
          <option value="0.85">Nexora Quantum Workspace Core (85% Overhead Mitigation)</option>
        </select>
      </div>
    </div>

    <div class="calc-results">
      <div class="results-inner">
        <span class="results-meta-title">Recaptured Human Capital Assets</span>
        <div class="metric-output" id="hours-saved-result-{{ section.id }}">22.8</div>
        <span class="results-unit">Hours Restored / Weekly Cycle</span>
        
        <div class="horizontal-divider"></div>
        
        <div class="annual-roi-row">
          <span class="roi-label">Calculated Annual Rest Days Reclaimed</span>
          <span class="roi-value" id="annual-days-{{ section.id }}">49 Days</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .calculator-section { padding: 6rem 2rem; }
  .calc-grid { display: grid; grid-template-columns: 1fr 1fr; border-radius: 12px; overflow: hidden; }
  .calc-inputs { padding: 4rem; }
  .calc-inputs h2 { font-size: 2.25rem; margin-bottom: 0.5rem; font-weight: 600; }
  .calc-desc { color: var(--color-text-muted); margin-bottom: 3rem; font-size: 1rem; line-height: 1.5; }
  
  .input-group { margin-bottom: 2.5rem; display: flex; flex-direction: column; }
  .input-group label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; color: var(--color-text-muted); font-weight: 500; }
  
  .slider {
    -webkit-appearance: none;
    width: 100%;
    height: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    outline: none;
  }
  .slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-accent-blue);
    cursor: pointer;
    transition: transform 0.1s ease;
  }
  .slider::-webkit-slider-thumb:hover { transform: scale(1.2); }

  .value-display { font-size: 1.25rem; font-weight: 600; margin-top: 0.75rem; color: #fff; }
  
  .calc-select {
    background: #121216;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 1rem;
    border-radius: 4px;
    font-size: 1rem;
    outline: none;
    cursor: pointer;
  }

  .calc-results { background: rgba(0, 113, 227, 0.03); padding: 4rem; display: flex; align-items: center; justify-content: center; border-left: 1px solid rgba(255,255,255,0.05); }
  .results-inner { text-align: center; width: 100%; }
  .results-meta-title { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-accent-blue); display: block; margin-bottom: 1rem; }
  .metric-output { font-size: clamp(4rem, 8vw, 7rem); font-weight: 700; color: #fff; line-height: 1; }
  .results-unit { color: var(--color-text-muted); font-size: 1rem; display: block; margin-top: 0.5rem; }
  .horizontal-divider { height: 1px; background: rgba(255,255,255,0.08); margin: 2.5rem 0; }
  
  .roi-label { font-size: 0.85rem; color: var(--color-text-muted); display: block; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .roi-value { font-size: 2.5rem; font-weight: 600; color: #fff; display: block; }

  @media (max-width: 991px) {
    .calc-grid { grid-template-columns: 1fr; }
    .calc-inputs, .calc-results { padding: 2.5rem; }
    .calc-results { border-left: none; border-top: 1px solid rgba(255,255,255,0.05); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = "{{ section.id }}";
    const hoursSlider = document.getElementById('hours-spent-' + sectionId);
    const hoursValue = document.getElementById('hours-value-' + sectionId);
    const efficiencySelect = document.getElementById('device-efficiency-' + sectionId);
    const hoursSavedOutput = document.getElementById('hours-saved-result-' + sectionId);
    const annualDaysOutput = document.getElementById('annual-days-' + sectionId);

    function calculateROI() {
      if(!hoursSlider || !efficiencySelect) return;
      const currentHours = parseFloat(hoursSlider.value);
      const efficiencyFactor = parseFloat(efficiencySelect.value);
      
      const weeklySaved = (currentHours * efficiencyFactor).toFixed(1);
      const annualSavedHours = weeklySaved * 52;
      const annualSavedDays = Math.round(annualSavedHours / 24);

      hoursValue.textContent = currentHours + ' Hours';
      hoursSavedOutput.textContent = weeklySaved;
      annualDaysOutput.textContent = annualSavedDays + ' Days';
    }

    if(hoursSlider && efficiencySelect) {
      hoursSlider.addEventListener('input', calculateROI);
      efficiencySelect.addEventListener('change', calculateROI);
      calculateROI();
    }
  });
</script>

{% schema %}
{
  "name": "Productivity ROI Engine",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quantify Human Leverage Optimization"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Determine the structural time optimization matrix achieved when routing data logic overhead through local hardware arrays."
    }
  ],
  "presets": [
    {
      "name": "Productivity ROI Engine"
    }
  ]
}
{% endschema %}
