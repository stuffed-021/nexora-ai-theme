{% comment %}
  Reusable Architecture Snippet Component for Rendering System-wide Catalog Item Matrices
  Accepts: product_item {Product Object}
{% endcomment %}

<div class="mock-product-card glass-panel hover-lift">
  <div class="mock-img-placeholder">
    {% if product_item.featured_image != blank %}
      <img src="{{ product_item.featured_image | image_url: width: 600 }}" 
           alt="{{ product_item.featured_image.alt | escape }}" 
           loading="lazy" 
           style="width:100%; height:100%; object-fit:cover;">
    {% else %}
      {{ product_item.title | upcase }} <br><br> HARDWARE MASTER VISUAL ASSET RESERVED
    {% endif %}
  </div>
  <div class="mock-card-meta">
    <h4>{{ product_item.title }}</h4>
    <p class="mock-price">{{ product_item.price | money }}</p>
    <a href="{{ product_item.url }}" class="btn-nexora" style="padding: 0.75rem 1.5rem; font-size: 0.85rem; width: 100%; text-align: center;">Initialize Evaluation Matrix</a>
  </div>
</div>
